# Top-level ignores. Per-subproject ignores live alongside (e.g. client/.gitignore).

# Go server build artifacts
server/server
server/server_*
server/*.test
server/data/

# Logs
*.log

# Editor / OS noise
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Hyacinth content packs — track sources, ignore build artifacts.
# (See .claude/skills/hyacinth-pack/SKILL.md.)
# pnpm-lock.yaml IS tracked — lockfiles belong in source control.
packs/*/node_modules/
packs/*/dist/
packs/*/pack.zip
packs/*/.pnpm-store/
